*.joblib
!prompthound/classifier/artifact/*.joblib

# Benchmark results (regenerated by run_benchmark.py — don't commit local runs)
benchmark/results/comparison.csv
benchmark/results/comparison.md
# Keep selected_model.json (records which run was promoted — provenance)
# benchmark/results/selected_model.json is intentionally NOT ignored

