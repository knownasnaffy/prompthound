# Virtual environments
.venv/
venv/
env/

# Python bytecode
__pycache__/
*.py[cod]
*.pyo

# Build / packaging
*.egg-info/
dist/
build/
*.egg
.eggs/

# Joblib build artifacts (NOT the committed model artifact in classifier/artifact/)
